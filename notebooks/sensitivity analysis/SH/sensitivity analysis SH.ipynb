        "# ============================================================\n",
        "# SENSITIVITY — Bar Plot, Scatter Plots & Final Summary\n",
        "# ============================================================\n",
        "ok_items = [(k, v) for k, v in all_results.items() if v.get(\"status\") == \"OK\"]\n",
        "\n",
        "# ── 1. Summary Bar: Best Val Loss ──\n",

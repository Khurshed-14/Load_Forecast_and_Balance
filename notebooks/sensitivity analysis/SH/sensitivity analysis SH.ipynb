        "#reproducibility and baseline\n",
        "SEED = 42\n",
        "\n",
        "torch.manual_seed(SEED)\n",
        "np.random.seed(SEED)\n",
        "\n",
        "#from baseline metrics\n",
        "BASELINE_VAL_LOSS = 0.1265770\n",
        "\n",
        "# Sensitivity target model\n",
        "SENSITIVITY_MODEL_CLS = TR_GNN_MultiScale"
      ]
